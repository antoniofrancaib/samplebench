{
  "checkpoint": {
    "adapter": "command",
    "family": "fmlm",
    "path": "checkpoints/owt/fmlm/distilled/model.ckpt"
  },
  "dataset": "owt",
  "generation": {
    "algo": "fmlm",
    "backend": "flm-hydra",
    "gamma": 1.0,
    "nfe": 16,
    "paper_aligned": true
  },
  "generation_command": [
    "python3",
    "scripts/generate_corpus.py",
    "flm-hydra",
    "--checkpoint",
    "{checkpoint_path}",
    "--output",
    "{output}",
    "--dataset",
    "{dataset}",
    "--suite-id",
    "{suite_id}",
    "--model-id",
    "{model_id}",
    "--label",
    "{label}",
    "--seq-len",
    "{seq_len}",
    "--n-samples",
    "{n_samples}",
    "--seed",
    "{seed}",
    "--algo",
    "fmlm",
    "--steps",
    "16",
    "--nfe",
    "16",
    "--eval-batch-size",
    "16",
    "--double-temb",
    "true",
    "--learnable-loss-weighting",
    "false",
    "--disable-ema",
    "false",
    "--gamma",
    "1.0"
  ],
  "label": "FMLM 16-NFE",
  "model_id": "owt_v2_fmlm_16_nfe",
  "n_samples": 1024,
  "sample_path": "samples.jsonl",
  "sampling": {
    "note": "Pure diffusion-vs-diffusion preference study (SampleBench v2). Samples standardized to ~256-token excerpt window before human display and metric computation to neutralize length confounds.\n",
    "protocol": "paper_gen_ppl",
    "study": "samplebench_v2",
    "tokenizer": "gpt2"
  },
  "schema_version": "lm-bench-samples-v1",
  "seed": 1,
  "seq_len": 1024,
  "source": "https://github.com/david3684/flm",
  "source_type": "checkpoint",
  "suite_id": "owt_L1024_diffusion_v2"
}
