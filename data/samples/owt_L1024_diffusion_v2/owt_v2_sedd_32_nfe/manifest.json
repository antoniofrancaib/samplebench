{
  "checkpoint": {
    "adapter": "command",
    "family": "sedd",
    "path": "checkpoints/owt/sedd/base/model.ckpt"
  },
  "dataset": "owt",
  "generation": {
    "algo": "sedd",
    "backend": "flm-hydra",
    "nfe": 32,
    "paper_aligned": true,
    "predictor": "analytic"
  },
  "generation_command": [
    "python3",
    "scripts/generate_corpus.py",
    "flm-hydra",
    "--checkpoint",
    "{checkpoint_path}",
    "--output",
    "{output}",
    "--dataset",
    "{dataset}",
    "--suite-id",
    "{suite_id}",
    "--model-id",
    "{model_id}",
    "--label",
    "{label}",
    "--seq-len",
    "{seq_len}",
    "--n-samples",
    "{n_samples}",
    "--seed",
    "{seed}",
    "--algo",
    "sedd",
    "--steps",
    "32",
    "--nfe",
    "32",
    "--eval-batch-size",
    "8",
    "--predictor",
    "analytic"
  ],
  "label": "SEDD 32-NFE",
  "model_id": "owt_v2_sedd_32_nfe",
  "n_samples": 1024,
  "sample_path": "samples.jsonl",
  "sampling": {
    "note": "Pure diffusion-vs-diffusion preference study (SampleBench v2). Samples standardized to ~256-token excerpt window before human display and metric computation to neutralize length confounds.\n",
    "protocol": "paper_gen_ppl",
    "study": "samplebench_v2",
    "tokenizer": "gpt2"
  },
  "schema_version": "lm-bench-samples-v1",
  "seed": 1,
  "seq_len": 1024,
  "source": "https://huggingface.co/louaaron/sedd-medium",
  "source_type": "checkpoint",
  "suite_id": "owt_L1024_diffusion_v2"
}
